---
import { Briefcase, Building2, User, Users } from "lucide-react"

const profiles = [
  {
    title: "Profesionales",
    text: "Compra, consolidación o metas personales.",
    icon: Briefcase,
  },
  {
    title: "Familias",
    text: "Vivienda, movilidad y decisiones patrimoniales.",
    icon: Users,
  },
  {
    title: "Emprendedores",
    text: "Capital, vehículo o crecimiento operativo.",
    icon: Building2,
  },
  {
    title: "Independientes",
    text: "Primeras decisiones con guía financiera.",
    icon: User,
  },
]
---

<section class="bg-white py-16 sm:py-20">
  <div class="mx-auto max-w-7xl px-5 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[0.76fr_1.24fr] lg:items-end">
      <div data-motion="reveal">
        <p class="section-eyebrow">Clientes</p>
        <h2
          class="mt-3 text-2xl font-black text-[var(--nexus-blue-dark)] sm:text-3xl"
        >
          Para personas que necesitan respaldo antes de decidir.
        </h2>
      </div>
      <p
        class="max-w-2xl text-base leading-7 text-[var(--nexus-gray)]"
        data-motion="reveal"
      >
        Trabajamos con perfiles que quieren revisar opciones reales, no avanzar
        a ciegas con una cuota que después no encaja.
      </p>
    </div>

    <div
      class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4"
      data-motion-group
    >
      {
        profiles.map(({ title, text, icon: Icon }) => (
          <article
            class="rounded-lg border border-[var(--nexus-line)] bg-[var(--nexus-cream)] p-5"
            data-motion-item
          >
            <Icon
              className="size-6 text-[var(--nexus-green)]"
              aria-hidden="true"
            />
            <h3 class="mt-5 text-xl font-black text-[var(--nexus-blue-dark)]">
              {title}
            </h3>
            <p class="mt-2 text-sm leading-6 text-[var(--nexus-gray)]">
              {text}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>
