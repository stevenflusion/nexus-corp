---
const steps = [
  [
    "01",
    "Entendemos tu meta",
    "Identificamos qué quieres lograr y qué plazo tienes en mente.",
  ],
  [
    "02",
    "Analizamos tu perfil financiero",
    "Revisamos capacidad, ingresos, compromisos y documentos base.",
  ],
  [
    "03",
    "Simulamos escenarios posibles",
    "Comparamos montos, cuotas y plazos referenciales.",
  ],
  [
    "04",
    "Te orientamos con alternativas claras",
    "Explicamos requisitos y opciones sin prometer aprobación.",
  ],
  [
    "05",
    "Te acompañamos en la siguiente decisión",
    "Definimos próximos pasos para avanzar con mayor seguridad.",
  ],
]
---

<section id="proceso" class="scroll-mt-24 bg-white py-16 sm:py-20">
  <div class="mx-auto max-w-7xl px-5 lg:px-8">
    <div class="mx-auto max-w-3xl text-center" data-motion="reveal">
      <p class="section-eyebrow">Proceso</p>
      <h2
        class="mt-3 text-2xl font-black text-[var(--nexus-blue-dark)] sm:text-3xl"
      >
        Así te acompañamos.
      </h2>
    </div>

    <div
      class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-5"
      data-motion-group
    >
      {
        steps.map(([number, title, text]) => (
          <article
            class="rounded-lg border border-[var(--nexus-line)] bg-white p-5"
            data-motion-item
          >
            <p class="text-3xl leading-none font-black text-[var(--nexus-gold-dark)] tabular-nums sm:text-4xl">
              {number}
            </p>
            <h3 class="mt-5 text-lg font-black text-[var(--nexus-blue-dark)]">
              {title}
            </h3>
            <p class="mt-2 text-sm leading-6 text-[var(--nexus-gray)]">
              {text}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>
