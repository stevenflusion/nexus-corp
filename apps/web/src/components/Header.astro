---
import { ArrowRight, Menu, X } from "lucide-react"
import BrandLogo from "./BrandLogo.astro"
import ThemeToggle from "./ThemeToggle.astro"

const navItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Nosotros", href: "/nosotros/" },
  { label: "Webinar", href: "/webinar/" },
  { label: "Contacto", href: "/contacto/" },
]

const normalizePath = (path: string) =>
  path === "/" ? "/" : path.endsWith("/") ? path : `${path}/`

const currentPath = normalizePath(Astro.url.pathname)
const isActive = (href: string) =>
  href === "/" ? currentPath === "/" : currentPath.startsWith(href)
---

<header
  class="sticky top-0 z-50 border-b border-[var(--nexus-line)] bg-white/90 backdrop-blur-xl"
>
  <nav
    class="mx-auto flex h-18 max-w-7xl items-center justify-between gap-5 px-5 lg:px-8"
    aria-label="Navegacion principal"
  >
    <a href="/" class="shrink-0 rounded-lg" aria-label="Ir al inicio">
      <BrandLogo compact />
    </a>

    <div
      class="hidden items-center gap-7 text-sm font-semibold text-[var(--nexus-gray)] lg:flex"
    >
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class={`transition hover:text-[var(--nexus-green)] ${
              isActive(item.href) ? "text-[var(--nexus-green)]" : ""
            }`}
            aria-current={isActive(item.href) ? "page" : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </div>

    <div class="flex shrink-0 items-center gap-2">
      <ThemeToggle />

      <a
        href="/cotizador/"
        class="group hidden items-center gap-2 rounded-lg bg-[var(--nexus-green)] px-5 py-3 text-sm font-extrabold text-white transition hover:bg-[var(--nexus-green-business)] lg:inline-flex"
      >
        Cotiza con nosotros
        <ArrowRight
          className="size-4 transition group-hover:translate-x-0.5"
          aria-hidden="true"
        />
      </a>

      <button
        type="button"
        class="inline-flex size-11 items-center justify-center rounded-lg border border-[var(--nexus-line)] bg-white text-[var(--nexus-blue-dark)] shadow-sm transition hover:border-[var(--nexus-blue)]/25 lg:hidden"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Abrir menu"
        data-menu-button
      >
        <Menu className="size-5" aria-hidden="true" data-menu-open />
        <X className="hidden size-5" aria-hidden="true" data-menu-close />
      </button>
    </div>
  </nav>

  <div
    id="mobile-menu"
    class="mx-4 mb-4 rounded-lg border border-[var(--nexus-line)] bg-white p-3 shadow-[0_20px_60px_rgba(0,31,61,0.12)] lg:hidden"
    aria-hidden="true"
    data-mobile-menu
    hidden
  >
    <div class="grid gap-1">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class={`rounded-lg px-4 py-3 text-base font-bold text-[var(--nexus-blue-dark)] transition hover:bg-[var(--nexus-cream)] ${
              isActive(item.href) ? "bg-[var(--nexus-cream)]" : ""
            }`}
            aria-current={isActive(item.href) ? "page" : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </div>
    <a
      href="/cotizador/"
      class="mt-3 inline-flex w-full items-center justify-center gap-2 rounded-lg bg-[var(--nexus-green)] px-5 py-3 text-sm font-extrabold text-white"
    >
      Cotiza con nosotros
      <ArrowRight className="size-4" aria-hidden="true" />
    </a>
  </div>
</header>

<script>
  const button = document.querySelector<HTMLButtonElement>("[data-menu-button]")
  const menu = document.querySelector<HTMLElement>("[data-mobile-menu]")

  const setMenuState = (open: boolean) => {
    button?.setAttribute("aria-expanded", String(open))
    button?.setAttribute("aria-label", open ? "Cerrar menu" : "Abrir menu")
    menu?.toggleAttribute("hidden", !open)
    menu?.setAttribute("aria-hidden", String(!open))
  }

  button?.addEventListener("click", () => {
    const open = button.getAttribute("aria-expanded") !== "true"
    setMenuState(open)
  })

  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => setMenuState(false))
  })

  window.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      setMenuState(false)
    }
  })
</script>

<style>
  [data-menu-button][aria-expanded="true"] [data-menu-open] {
    display: none;
  }

  [data-menu-button][aria-expanded="true"] [data-menu-close] {
    display: block;
  }

  [data-mobile-menu]:not([hidden]) {
    animation: menu-in 180ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  @keyframes menu-in {
    from {
      transform: translateY(-0.35rem);
      opacity: 0;
    }

    to {
      transform: translateY(0);
      opacity: 1;
    }
  }
</style>
