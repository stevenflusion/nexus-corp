---
import CTA from "../components/CTA.astro"
import Footer from "../components/Footer.astro"
import Header from "../components/Header.astro"
import Hero from "../components/Hero.astro"
import MotionViewport from "../components/MotionViewport"
import Process from "../components/Process.astro"
import Services from "../components/Services.astro"
import SocialProof from "../components/SocialProof.astro"
import TrustSection from "../components/TrustSection.astro"
import MainLayout from "../layouts/main.astro"
---

<MainLayout
  title="NEXUS | Asesoría financiera para tus metas"
  description="NEXUS ayuda a personas, familias y emprendedores en Ecuador a entender sus opciones financieras para vivienda, vehículo y consumo."
>
  <Header />
  <main id="contenido">
    <Hero />
    <TrustSection />
    <Services />
    <SocialProof />
    <Process />
    <CTA />
  </main>
  <Footer />
  <MotionViewport client:load />
</MainLayout>
