---
import "@workspace/ui/globals.css"
import N8nChat from "../components/chatbot/N8nChat"

interface Props {
  title?: string
  description?: string
  ogImage?: string
}

const {
  title = "NEXUS | Asesoría financiera para tus metas",
  description = "NEXUS acompaña a personas, familias y emprendedores a entender sus opciones financieras para vivienda, vehículo y consumo.",
  ogImage = "/branding/ref2.jpeg",
} = Astro.props

const siteUrl = Astro.site?.toString() ?? "https://www.nexuscorpec.com"
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString()
const imageUrl = new URL(ogImage, siteUrl).toString()
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="preload" as="image" href="/branding/nexus-logo-cropped.png" />
    <link rel="preload" as="image" href="/branding/logo-oscuro.png" />
    <link
      rel="preload"
      as="image"
      href="/branding/financial-analysis-desk.jpg"
    />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ffffff" />
    <meta name="robots" content="index, follow" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_EC" />
    <meta property="og:site_name" content="NEXUS" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <title>{title}</title>
    <script is:inline>
      ;(() => {
        try {
          const storageKey = "nexus-site-theme"
          const storedTheme = window.localStorage.getItem(storageKey)
          const prefersDark = window.matchMedia(
            "(prefers-color-scheme: dark)"
          ).matches
          const theme =
            storedTheme === "light" || storedTheme === "dark"
              ? storedTheme
              : prefersDark
                ? "dark"
                : "light"

          document.documentElement.dataset.theme = theme
          document.documentElement.style.colorScheme = theme
        } catch {
          document.documentElement.dataset.theme = "light"
          document.documentElement.style.colorScheme = "light"
        }
      })()
    </script>
  </head>
  <body>
    <a class="skip-link" href="#contenido">Saltar al contenido</a>
    <slot />
    <N8nChat client:load />
    <script>
      window.addEventListener("keydown", (event) => {
        if (event.key === "Tab") {
          document.body.dataset.inputMode = "keyboard"
        }
      })

      window.addEventListener("pointerdown", () => {
        delete document.body.dataset.inputMode
      })
    </script>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --nexus-blue: #002b55;
    --nexus-blue-dark: #001f3d;
    --nexus-blue-mid: #0d4575;
    --nexus-blue-professional: #1a5e9a;
    --nexus-blue-light: #3a7cb8;
    --nexus-green: #009933;
    --nexus-green-dark: #006b24;
    --nexus-green-business: #00b140;
    --nexus-green-success: #1ac65b;
    --nexus-green-premium: #38e86f;
    --nexus-gold: #c89b3c;
    --nexus-gold-soft: #d9b56d;
    --nexus-gold-dark: #a87a1f;
    --nexus-bronze: #8f6a2e;
    --nexus-gray: #4d5b6a;
    --nexus-gray-soft: #a9b3c1;
    --nexus-line-soft: #d9dee5;
    --nexus-cream: #f4f6f8;
    --nexus-ink: #001f3d;
    --nexus-paper: #ffffff;
    --nexus-white: #ffffff;
    --nexus-line: rgba(0, 43, 85, 0.12);
    --nexus-shadow: 0 28px 80px rgba(0, 31, 61, 0.13);
  }

  :root[data-theme="dark"] {
    color-scheme: dark;
    --nexus-gray: #c7d3e2;
    --nexus-gray-soft: #7f91a8;
    --nexus-line-soft: rgba(199, 211, 226, 0.22);
    --nexus-cream: #101d2e;
    --nexus-ink: #f4f8fd;
    --nexus-paper: #07111f;
    --nexus-white: #0b1727;
    --nexus-line: rgba(199, 211, 226, 0.16);
    --nexus-shadow: 0 28px 90px rgba(0, 0, 0, 0.42);
  }

  html {
    background: var(--nexus-paper);
  }

  body {
    min-width: 320px;
    overflow-x: hidden;
    background: var(--nexus-paper);
    color: var(--nexus-ink);
    font-family: var(--font-sans);
    text-rendering: geometricPrecision;
  }

  :root[data-theme="dark"] body {
    background:
      radial-gradient(
        circle at 18% 0%,
        rgba(0, 153, 51, 0.16),
        transparent 30rem
      ),
      radial-gradient(
        circle at 88% 8%,
        rgba(200, 155, 60, 0.13),
        transparent 26rem
      ),
      var(--nexus-paper);
  }

  :root[data-theme="dark"] .bg-white {
    background-color: var(--nexus-white) !important;
  }

  :root[data-theme="dark"] [class~="bg-white/90"] {
    background-color: rgba(11, 23, 39, 0.9) !important;
  }

  :root[data-theme="dark"] [class~="bg-white/92"] {
    background-color: rgba(11, 23, 39, 0.92) !important;
  }

  :root[data-theme="dark"] [class~="bg-white/96"] {
    background-color: rgba(11, 23, 39, 0.96) !important;
  }

  :root[data-theme="dark"] [class*="text-[var(--nexus-blue-dark)]"] {
    color: var(--nexus-ink) !important;
  }

  :root[data-theme="dark"] [class*="text-[var(--nexus-blue)]"] {
    color: #8bd5ff !important;
  }

  :root[data-theme="dark"] input,
  :root[data-theme="dark"] select,
  :root[data-theme="dark"] textarea {
    background-color: #0f1d30 !important;
    color: var(--nexus-ink) !important;
  }

  :root[data-theme="dark"] input::placeholder,
  :root[data-theme="dark"] textarea::placeholder {
    color: rgba(199, 211, 226, 0.58);
  }

  :root[data-theme="dark"] img {
    color: transparent;
  }

  ::selection {
    color: #ffffff;
    background: rgba(0, 113, 39, 0.72);
  }

  .skip-link {
    position: fixed;
    top: 1rem;
    left: 1rem;
    z-index: 100;
    pointer-events: none;
    visibility: hidden;
    opacity: 0;
    transform: translateY(-180%);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 0.75rem;
    background: var(--nexus-blue);
    padding: 0.7rem 1rem;
    color: #ffffff;
    font-weight: 700;
    transition: transform 180ms ease;
  }

  body[data-input-mode="keyboard"] .skip-link:focus {
    visibility: visible;
    opacity: 1;
    transform: translateY(0);
    outline: 3px solid rgba(0, 113, 39, 0.45);
  }

  :focus-visible {
    outline: 3px solid rgba(0, 113, 39, 0.62);
    outline-offset: 4px;
  }

  .section-eyebrow {
    color: var(--nexus-green);
    font-size: 0.74rem;
    font-weight: 850;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .nexus-section {
    padding-block: clamp(5rem, 8vw, 7rem);
  }

  .nexus-card {
    border: 1px solid var(--nexus-line);
    border-radius: 0.5rem;
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 18px 50px rgba(0, 32, 35, 0.08);
  }

  .nexus-panel {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--nexus-line);
    border-radius: 0.5rem;
    background: var(--nexus-paper);
    color: var(--nexus-ink);
    box-shadow: var(--nexus-shadow);
  }

  .nexus-panel::before {
    position: absolute;
    inset: 0;
    pointer-events: none;
    content: "";
    background:
      linear-gradient(90deg, rgba(0, 43, 85, 0.05) 1px, transparent 1px),
      linear-gradient(180deg, rgba(0, 43, 85, 0.04) 1px, transparent 1px);
    background-size: 72px 72px;
    mask-image: linear-gradient(135deg, black, transparent 78%);
  }

  .theme-toggle {
    position: relative;
    display: inline-grid;
    width: 2.75rem;
    height: 2.75rem;
    place-items: center;
    flex: 0 0 auto;
    border: 1px solid var(--nexus-line);
    border-radius: 0.5rem;
    background: color-mix(in srgb, var(--nexus-white) 92%, transparent);
    color: var(--nexus-blue-dark);
    box-shadow: 0 10px 28px rgba(0, 31, 61, 0.1);
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background 180ms ease,
      color 180ms ease;
  }

  .theme-toggle:hover {
    transform: translateY(-1px);
    border-color: rgba(0, 153, 51, 0.38);
    color: var(--nexus-green);
  }

  .theme-toggle__icon {
    position: absolute;
    width: 1.15rem;
    height: 1.15rem;
    transition:
      opacity 160ms ease,
      transform 160ms ease;
  }

  .theme-toggle__icon--sun {
    opacity: 1;
    transform: rotate(0deg) scale(1);
  }

  .theme-toggle__icon--moon {
    opacity: 0;
    transform: rotate(-18deg) scale(0.72);
  }

  :root[data-theme="dark"] .theme-toggle {
    background: rgba(16, 29, 46, 0.92);
    color: #f7d78a;
    box-shadow: 0 12px 34px rgba(0, 0, 0, 0.28);
  }

  :root[data-theme="dark"] .theme-toggle__icon--sun {
    opacity: 0;
    transform: rotate(18deg) scale(0.72);
  }

  :root[data-theme="dark"] .theme-toggle__icon--moon {
    opacity: 1;
    transform: rotate(0deg) scale(1);
  }

  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      scroll-behavior: auto !important;
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>
