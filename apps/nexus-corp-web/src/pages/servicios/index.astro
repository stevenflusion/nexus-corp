---
import {
  ArrowRight,
  BadgeCheck,
  Car,
  ClipboardCheck,
  CreditCard,
  Handshake,
  Home,
  LineChart,
  SearchCheck,
  ShieldCheck,
  Target,
} from "lucide-react"
import CTA from "../../components/CTA.astro"
import Footer from "../../components/Footer.astro"
import Header from "../../components/Header.astro"
import MotionViewport from "../../components/MotionViewport"
import MainLayout from "../../layouts/main.astro"

const services = [
  {
    title: "Asesoría Vehicular",
    text: "Analizamos tu perfil financiero, simulamos diferentes escenarios y te guiamos para que tomes decisiones informadas antes de buscar opciones de financiamiento.",
    details: [
      "Monto, entrada y plazo referencial.",
      "Capacidad mensual y documentos base.",
      "Ruta clara antes de conversar con una entidad.",
    ],
    icon: Car,
    accent: "var(--nexus-green)",
  },
  {
    title: "Asesoría para Vivienda",
    text: "Analizamos tu perfil financiero, simulamos diferentes escenarios y te ayudamos a identificar las mejores alternativas para compra, construcción o remodelación.",
    details: [
      "Compra, construcción o remodelación.",
      "Lectura de capacidad y cuota referencial.",
      "Preparación de información patrimonial.",
    ],
    icon: Home,
    accent: "var(--nexus-blue-professional)",
  },
  {
    title: "Asesoría para Crédito de Consumo",
    text: "Antes de asumir un compromiso financiero, te orientamos para que conozcas tus posibilidades y elijas una alternativa acorde a tu realidad.",
    details: [
      "Necesidades personales o familiares.",
      "Impacto mensual y alertas de flujo.",
      "Alternativas claras antes de decidir.",
    ],
    icon: CreditCard,
    accent: "var(--nexus-gold)",
  },
]

const processSteps = [
  {
    number: "01",
    title: "Entendemos tu meta",
    text: "Conversamos sobre lo que quieres lograr y el plazo que tienes en mente.",
    icon: Target,
  },
  {
    number: "02",
    title: "Analizamos tu perfil financiero",
    text: "Revisamos ingresos, compromisos, capacidad y documentos base.",
    icon: SearchCheck,
  },
  {
    number: "03",
    title: "Simulamos escenarios posibles",
    text: "Comparamos montos, cuotas y plazos referenciales para dar contexto.",
    icon: LineChart,
  },
  {
    number: "04",
    title: "Te orientamos con alternativas claras",
    text: "Explicamos opciones, requisitos y consideraciones sin prometer aprobación.",
    icon: ClipboardCheck,
  },
  {
    number: "05",
    title: "Te acompañamos en la siguiente decisión",
    text: "Definimos próximos pasos para que avances con mayor seguridad.",
    icon: Handshake,
  },
]

const benefits = [
  {
    title: "Claridad antes de comprometerte",
    text: "Entiendes cuota, capacidad y requisitos antes de avanzar.",
    icon: BadgeCheck,
  },
  {
    title: "Acompañamiento personalizado",
    text: "Cada caso parte de tu realidad financiera y tu objetivo.",
    icon: Handshake,
  },
  {
    title: "Información responsable",
    text: "NEXUS asesora; no otorga crédito directo ni promete aprobación.",
    icon: ShieldCheck,
  },
]
---

<MainLayout
  title="Servicios NEXUS | Asesoría financiera para tus metas"
  description="Servicios de asesoría financiera NEXUS para revisar alternativas de vivienda, vehículo y consumo con claridad."
>
  <Header />
  <main id="contenido">
    <section
      class="border-b border-[var(--nexus-line)] bg-white py-14 text-[var(--nexus-blue-dark)] sm:py-18"
    >
      <div
        class="mx-auto grid max-w-7xl gap-8 px-5 lg:grid-cols-[0.86fr_1.14fr] lg:items-center lg:px-8"
      >
        <div data-motion="reveal">
          <p class="text-sm font-black text-[var(--nexus-green)] uppercase">
            Servicios
          </p>
          <h1 class="mt-3 text-3xl leading-tight font-black sm:text-4xl">
            Te ayudamos a entender tus opciones antes de tomar una decisión
            financiera.
          </h1>
          <p
            class="mt-5 max-w-2xl text-base leading-7 text-[var(--nexus-gray)]"
          >
            NEXUS no entrega crédito directo. Te acompaña a revisar capacidad,
            documentos, escenarios y siguientes pasos para tus metas de
            vivienda, vehículo o consumo.
          </p>
          <div class="mt-7 flex flex-col gap-3 sm:flex-row">
            <a
              href="/cotizador/"
              class="inline-flex min-h-12 items-center justify-center gap-3 rounded-lg bg-[var(--nexus-green)] px-5 py-4 text-sm font-black text-white transition hover:bg-[var(--nexus-green-business)]"
            >
              Cotiza con nosotros
              <ArrowRight className="size-5" aria-hidden="true" />
            </a>
          </div>
        </div>

        <figure
          class="overflow-hidden rounded-lg border border-[var(--nexus-line)] bg-white shadow-xl shadow-[rgba(0,31,61,0.10)]"
          data-motion="reveal"
        >
          <img
            src="/branding/financial-analysis-desk.jpg"
            alt="Mesa de análisis financiero con documentos y reportes."
            class="h-64 w-full object-cover sm:h-80"
            loading="lazy"
          />
          <figcaption
            class="p-5 text-sm leading-6 font-bold text-[var(--nexus-gray)]"
          >
            Tus metas son importantes. Te ayudamos a entender tus opciones y
            encontrar el mejor camino para alcanzarlas.
          </figcaption>
        </figure>
      </div>
    </section>

    <section class="bg-white py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-5 lg:px-8">
        <div class="grid gap-6 lg:grid-cols-[0.8fr_1.2fr] lg:items-end">
          <div data-motion="reveal">
            <p class="section-eyebrow">Asesorías principales</p>
            <h2
              class="mt-3 text-2xl font-black text-[var(--nexus-blue-dark)] sm:text-3xl"
            >
              Servicios pensados para decidir con mejor información.
            </h2>
          </div>
          <p
            class="max-w-3xl text-base leading-7 text-[var(--nexus-gray)]"
            data-motion="reveal"
          >
            No prometemos aprobaciones ni resultados automáticos. Preparamos tu
            caso con números claros, posibles escenarios y una ruta de
            conversación responsable.
          </p>
        </div>

        <div class="mt-10 grid gap-4 lg:grid-cols-3" data-motion-group>
          {
            services.map(({ title, text, details, icon: Icon, accent }) => (
              <article
                class="rounded-lg border border-[var(--nexus-line)] bg-[var(--nexus-cream)] p-5 transition hover:-translate-y-1 hover:border-[var(--nexus-gold)] hover:bg-white hover:shadow-xl hover:shadow-[rgba(0,31,61,0.08)]"
                data-motion-item
              >
                <span
                  class="grid size-12 place-items-center rounded-lg text-white"
                  style={`background: ${accent}`}
                >
                  <Icon className="size-6" aria-hidden="true" />
                </span>
                <h2 class="mt-5 text-2xl font-black text-[var(--nexus-blue-dark)]">
                  {title}
                </h2>
                <p class="mt-3 text-sm leading-6 text-[var(--nexus-gray)]">
                  {text}
                </p>
                <ul class="mt-5 grid gap-2">
                  {details.map((detail) => (
                    <li class="flex gap-2 text-sm font-bold text-[var(--nexus-blue-dark)]">
                      <ShieldCheck
                        className="mt-0.5 size-4 shrink-0 text-[var(--nexus-green)]"
                        aria-hidden="true"
                      />
                      <span>{detail}</span>
                    </li>
                  ))}
                </ul>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="bg-white py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-5 lg:px-8">
        <div class="mx-auto max-w-3xl text-center" data-motion="reveal">
          <p class="section-eyebrow">Así te acompañamos</p>
          <h2
            class="mt-3 text-2xl font-black text-[var(--nexus-blue-dark)] sm:text-3xl"
          >
            Un proceso claro desde la meta hasta la siguiente decisión.
          </h2>
        </div>

        <div
          class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-5"
          data-motion-group
        >
          {
            processSteps.map(({ number, title, text, icon: Icon }) => (
              <article
                class="rounded-lg border border-[var(--nexus-line)] bg-white p-5"
                data-motion-item
              >
                <div class="flex items-center justify-between gap-3">
                  <span class="text-sm font-black text-[var(--nexus-gold-dark)]">
                    {number}
                  </span>
                  <Icon
                    className="size-5 text-[var(--nexus-green)]"
                    aria-hidden="true"
                  />
                </div>
                <h3 class="mt-5 text-lg font-black text-[var(--nexus-blue-dark)]">
                  {title}
                </h3>
                <p class="mt-2 text-sm leading-6 text-[var(--nexus-gray)]">
                  {text}
                </p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="bg-white py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-5 lg:px-8">
        <div class="grid gap-8 lg:grid-cols-[0.84fr_1.16fr] lg:items-start">
          <div data-motion="reveal">
            <p class="section-eyebrow">Beneficios</p>
            <h2
              class="mt-3 text-2xl font-black text-[var(--nexus-blue-dark)] sm:text-3xl"
            >
              Una buena decisión financiera empieza con información clara.
            </h2>
            <p class="mt-4 text-base leading-7 text-[var(--nexus-gray)]">
              En NEXUS te acompañamos a comparar opciones, entender requisitos y
              elegir el camino más adecuado para tu realidad.
            </p>
          </div>

          <div class="grid gap-4 sm:grid-cols-3" data-motion-group>
            {
              benefits.map(({ title, text, icon: Icon }) => (
                <article
                  class="rounded-lg border border-[var(--nexus-line)] bg-[var(--nexus-cream)] p-5"
                  data-motion-item
                >
                  <Icon
                    className="size-6 text-[var(--nexus-green)]"
                    aria-hidden="true"
                  />
                  <h3 class="mt-5 text-lg font-black text-[var(--nexus-blue-dark)]">
                    {title}
                  </h3>
                  <p class="mt-2 text-sm leading-6 text-[var(--nexus-gray)]">
                    {text}
                  </p>
                </article>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <CTA />
  </main>
  <Footer />
  <MotionViewport client:load />
</MainLayout>
